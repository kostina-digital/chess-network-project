# Copy to .env and .env.local, then adjust.

# Your setup (example): host 127.0.0.1, port 5433, database db
# DATABASE_URL=postgresql://admin:YOUR_PASSWORD@127.0.0.1:5433/db?schema=public

# Docker Compose in this repo (if you use it): postgres on 5432, DB chessnet
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chessnet?schema=public

# Neon / other managed Postgres (remote):
# IMPORTANT: special characters in password must be URL-encoded (`@` -> `%40`, `:` -> `%3A`, etc.).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require&channel_binding=require

DATABASE_URL=postgresql://admin:YOUR_PASSWORD@127.0.0.1:5433/db?schema=public
AUTH_SECRET=change_me_to_a_long_random_string

# https://gnews.io/ — used by /api/news (server-side only)
# GNEWS_API_KEY=
# Optional: articles requested per call (1–100). Free GNews tier still returns ~10 max per request.
# GNEWS_MAX_ARTICLES=100
